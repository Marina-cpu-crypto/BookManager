@model Book

@{
    ViewData["Title"] = "Подробнее о книге";

    string booktext = "";
    Guid MainId = Guid.Parse(System.IO.File.ReadAllText("Data/MainId.txt"));
    string file = "Data/" + MainId + "/Texts/" + @Model.Name + ".txt";  // исправлено отображение рецензии
    if (File.Exists(file)) booktext = string.Join(" ", File.ReadLines(file));
}


<form
    style="display:flex; flex-direction:column; gap:18px; padding:24px;
    border-radius:20px; background:white; box-shadow:0 4px 15px rgba(0,0,0,0.12);">

    <div style="display:flex; gap:15px; flex-wrap:wrap;">
        <div>
            <label class="search-input">Название</label>
            <input class="search-input" type="text" value="@Model.Name" name="Name" />
        </div>
        <div>
            <label class="search-input">Автор</label>
            <input class="search-input" type="text" value="@Model.Author" name="Author" />
        </div>
        <div>
            <label class="search-input">Жанр</label>
            <input class="search-input" type="text" value="@Model.Genre" name="Genre" />
        </div>
    </div>

    <div style="display:flex; gap:20px; flex-wrap:wrap;">
        <div style="flex:1; min-width:300px;">
            <label class="search-input">Описание сюжета</label>
            <textarea class="search-input" style="width:100%; height:250px; resize:none; margin-top:8px;" name="Description">@Model.Description</textarea>
        </div>
        <div style="flex:1; min-width:300px;">
            <label class="search-input">Рецензия</label>
            <textarea class="search-input" style="width:100%; height:250px; resize:none; margin-top:8px;" name="bookText">@booktext</textarea>
        </div>
    </div>

    <div style="display:flex; align-items:end; gap:15px; flex-wrap:wrap;">
        <div>
            <label class="search-input">Ссылка на изображение</label>
            <input class="search-input" style="width:300px; margin-top:8px;" name="PathImage" value="@Model.PathImage" placeholder="URL картинки"/>
        </div>
        <button class="btn btn-outline-success"
            type="submit"
            asp-controller="Book"
            asp-action="Save"
            asp-route-Id="@Model.Id">Сохранить изменения</button>
        <a class="btn btn-outline-danger"
           asp-controller="Book"
           asp-action="Delete"
           asp-route-Id="@Model.Id">Удалить книгу</a>
    </div>
</form>

   
