@model Book

@{
    ViewData["Title"] = "Подробнее о книге";

    string booktext = "";
    Guid MainId = Guid.Parse(System.IO.File.ReadAllText("Data/MainId.txt"));
    string file = "Data/" + MainId + "/Texts/" + @Model.Name + ".txt";  // исправлено отображение рецензии
    if (File.Exists(file)) booktext = string.Join(" ", File.ReadLines(file));
}


<form
    style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; padding:18px;
    border-radius:20px; background:white; box-shadow:0 4px 15px rgba(0,0,0,0.12);">
    <p>
        <label class="search-input">Название</label> <input class="search-input" type="text" value="@Model.Name" style="width:auto;" name="Name" />
        <label class="search-input">Автор</label> <input class="search-input"  type="text" value="@Model.Author" style="width:auto;" name="Author" />
        <label class="search-input">Жанр</label> <input class="search-input" type="text" value="@Model.Genre" style="width:auto;" name="Genre" />
    </p>
    <div style="display:flex; flex-direction:row">
        <p>
            <label class="search-input">Рецензия</label><br/>
            <textarea style="height:300px; width:800px; margin-inline:60px;"
            name="bookText"
            rows="8" cols="50">@booktext</textarea>

        <div class="w-30">
            <p>
                 <label class="search-input">Текущее описание сюжета</label><br />
                 <textarea class="search-input" style="width:350px; height:300px; resize:none;" name="Description">@Model.Description</textarea>
            </p>
            
        </div>
            
    </div>
    <div style="display:flex; flex-direction:row">
        <input class="search-input" placeholder="Ссылка на изображение" name="PathImage" value="@Model.PathImage"/>
        <button class="btn btn-outline-success"
            type="submit"
            asp-controller="Book"
            asp-action="Save"
            asp-route-Id="@Model.Id">Сохранить изменения </button>

        <a class="btn btn-outline-danger"
           asp-controller="Book"
           asp-action="Delete"
           asp-route-Id="@Model.Id">Удалить книгу</a>
    </div>
</form>

   
