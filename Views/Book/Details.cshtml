@model Documents.Models.Book
@{
    ViewData["Title"] = "Книга";
}

<h1>Информация о книге</h1>

<hr />

@if (Model != null)
{
    <h2>@Model.Name</h2>

    <p><b>Автор:</b> @Model.Author</p>

    <p><b>Жанр:</b> @Model.Genre</p>

    <p>
        <b>Описание:</b><br />
        @Model.Description
    </p>

    <p>
        <b>Статус:</b>
        @(Model.IsRead ? "Прочитана" : "Не прочитана")
    </p>

    <hr />

    <h3>Рецензия</h3>

    @if (!string.IsNullOrEmpty(Model.Review))
    {
        <p>@Model.Review</p>
    }
    else
    {
        <p><em>Рецензия не добавлена</em></p>
    }

    <hr />

    <div>
        <a href="/Book/Redact?id=@Model.Id" class="btn">Редактировать</a>
        <a href="/Book/ChangeReadStatus?id=@Model.Id" class="btn">
            @(Model.IsRead ? "Отметить как непрочитанную" : "Отметить как прочитанную")
        </a>
        <a href="/Book/Delete?id=@Model.Id" class="btn btn-danger" onclick="return confirm('Вы уверены?')">Удалить</a>
        <a href="/" class="btn">Назад</a>
    </div>
}
else
{
    <p><em>Книга не найдена</em></p>
}

<style>
    .btn {
        display: inline-block;
        padding: 8px 15px;
        margin: 5px 5px 5px 0;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        cursor: pointer;
    }

    .btn:hover {
        background-color: #0056b3;
    }

    .btn-danger {
        background-color: #dc3545;
    }

    .btn-danger:hover {
        background-color: #c82333;
    }
</style>
