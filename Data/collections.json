            "Genre": "\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439 \u0440\u043E\u043C\u0430\u043D",
            "IsDone": true,
            "Rating": 0,
            "Description": "\u0421\u044E\u0436\u0435\u0442 \u0440\u043E\u043C\u0430\u043D\u0430 \u0441\u0442\u0440\u043E\u0438\u0442\u0441\u044F \u043D\u0430 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0438 \u0432\u0437\u0440\u043E\u0441\u043B\u0435\u043D\u0438\u044F \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E \u0433\u0435\u0440\u043E\u044F, \u042D\u043C\u0438\u043B\u044F \u0421\u0438\u043D\u043A\u043B\u0435\u0440\u0430. \u041E\u043D \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442 \u043F\u0443\u0442\u044C \u043E\u0442 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u043D\u0435\u0433\u043E \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u0434\u043E \u0432\u0437\u0440\u043E\u0441\u043B\u043E\u0433\u043E, \u0437\u0440\u0435\u043B\u043E\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430. \u042D\u0442\u043E\u0442 \u043F\u0443\u0442\u044C \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0432\u0430\u0436\u043D\u044B\u0445 \u0434\u043B\u044F \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044F \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E \u0433\u0435\u0440\u043E\u044F \u044D\u0442\u0430\u043F\u043E\u0432.",
